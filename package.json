{
  "name": "carjan-app",
  "version": "1.0.0",
  "description": "CARJAN - CARLA Scenario Editor and Management Tool",
  "author": "Leonard Neis <leonard@neis-it.de>",
  "license": "MIT",
  "type": "module",
  "main": "src/main/index.js",
  "dependencies": {
    "@primeuix/themes": "^1.1.1",
    "animejs": "^4.0.2",
    "electron-store": "^10.0.1",
    "motion-v": "^1.2.1",
    "pinia": "^3.0.3",
    "primeicons": "^7.0.0",
    "primevue": "^4.3.4",
    "three": "^0.177.0",
    "vanta": "^0.5.24",
    "vue": "^3.5.14",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/ui": "^3.1.4",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.21",
    "concurrently": "^8.2.2",
    "electron": "^36.2.1",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.4",
    "jsdom": "^26.1.0",
    "vite": "^6.3.5",
    "vitest": "^3.1.4",
    "wait-on": "^7.2.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "electron:dist": "npm run build && electron-builder --publish=never",
    "electron:pack": "npm run build && electron-builder --dir",
    "test": "vitest run",
    "test:ui": "vitest --ui"
  },
  "vitest": {
    "include": [
      "src/**/*.test.js"
    ]
  },
  "build": {
    "appId": "com.leonardneis.carjan",
    "productName": "CARJAN",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "public",
        "to": "public",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/renderer/assets/img/marker.png"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "src/renderer/assets/img/marker.png"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/renderer/assets/img/marker.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
